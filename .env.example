# Server Configuration
NODE_ENV=production
PORT=3000

# Database (Render PostgreSQL - will migrate to Neon)
DATABASE_URL=your_render_postgresql_url_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=dhfzjdhjl
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Google Workspace)
EMAIL_USER=noreply@awaasset.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=noreply@awaasset.com
EMAIL_FROM_NAME=AWA Asset Management

# Security
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Rate Limiting
OTP_RATE_LIMIT=3
UPLOAD_RATE_LIMIT=10
ENROLL_RATE_LIMIT=5

# Frontend URL (for CORS)
FRONTEND_URL=https://awaasset.com
